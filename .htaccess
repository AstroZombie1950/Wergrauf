Options +FollowSymLinks
Options -Indexes
RewriteEngine On

RewriteBase /

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^shower_system/([a-z0-9_-]+)/?$       /shower_system/product.php?slug=$1       [L,QSA]
RewriteRule ^kitchen_faucets/([a-z0-9_-]+)/?$     /kitchen_faucets/product.php?slug=$1     [L,QSA]
RewriteRule ^floor_faucets/([a-z0-9_-]+)/?$       /floor_faucets/product.php?slug=$1       [L,QSA]
RewriteRule ^bath_faucets/([a-z0-9_-]+)/?$        /bath_faucets/product.php?slug=$1        [L,QSA]
RewriteRule ^sink_faucets/([a-z0-9_-]+)/?$        /sink_faucets/product.php?slug=$1        [L,QSA]
RewriteRule ^hygienic_shower/([a-z0-9_-]+)/?$     /hygienic_shower/product.php?slug=$1     [L,QSA]
RewriteRule ^accessories/([a-z0-9_-]+)/?$         /accessories/product.php?slug=$1         [L,QSA]
RewriteRule ^towel_warmers/([a-z0-9_-]+)/?$       /towel_warmers/product.php?slug=$1       [L,QSA]
RewriteRule ^components/([a-z0-9_-]+)/?$          /components/product.php?slug=$1          [L,QSA]

# Страницы ошибок
ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php

# --- Сжатие (gzip) ---
# AddOutputFilterByType — директива mod_filter, поэтому guard именно по нему
<IfModule mod_filter.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
	AddOutputFilterByType DEFLATE application/javascript application/json
	AddOutputFilterByType DEFLATE application/xml application/rss+xml
	AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --- Кэширование статики ---
<IfModule mod_expires.c>
	ExpiresActive On
	# Картинки и шрифты — на год (имена стабильны)
	ExpiresByType image/webp              "access plus 1 year"
	ExpiresByType image/jpeg              "access plus 1 year"
	ExpiresByType image/png               "access plus 1 year"
	ExpiresByType image/gif               "access plus 1 year"
	ExpiresByType image/svg+xml           "access plus 1 year"
	ExpiresByType image/x-icon            "access plus 1 year"
	ExpiresByType font/woff2              "access plus 1 year"
	ExpiresByType font/woff               "access plus 1 year"
	# CSS/JS — на неделю (чтобы правки доходили до пользователей)
	ExpiresByType text/css                "access plus 7 days"
	ExpiresByType application/javascript  "access plus 7 days"
	# HTML/XML (фид) не кэшируем — отдаются динамически
	ExpiresByType text/html               "access plus 0 seconds"
	ExpiresByType application/xml         "access plus 0 seconds"
</IfModule>

# --- Заголовки безопасности ---
<IfModule mod_headers.c>
	Header set X-Content-Type-Options "nosniff"
	Header set X-Frame-Options "SAMEORIGIN"
	Header set Referrer-Policy "strict-origin-when-cross-origin"
	# Статике добавляем immutable — браузер не перезапрашивает до истечения срока
	<FilesMatch "\.(webp|jpe?g|png|gif|svg|ico|woff2?)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
</IfModule>